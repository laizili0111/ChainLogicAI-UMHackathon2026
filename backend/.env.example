# ChainLogic AI Environment Variables Template
# Copy this file to .env and replace the values with your own API keys.

# Primary AI Model (Ilmu GLM)
ILMU_API_KEY=your_ilmu_api_key_here
ILMU_BASE_URL=https://api.ilmu.ai/v1/chat/completions
ILMU_MODEL=ilmu-glm-5.1

# Secondary Fallback Model (Groq - OpenAI GPT-OSS-120B)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=openai/gpt-oss-120b

# Tertiary Fallback Model (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database Config (Defaults to local SQLite)
DATABASE_URL=sqlite:///./chainlogic_erp.db
